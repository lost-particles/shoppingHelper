# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Required for Plan A (backend) — agent calls Subconscious model.
# Get one at: https://www.subconscious.dev/platform
SUBCONSCIOUS_API_KEY=sky_your_key_here

# Required for Plan C (data) — runs the Apify Wayfair scrape.
# Plans A and B do not need this.
# Get one at: https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_your_token_here
